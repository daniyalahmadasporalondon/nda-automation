# Copy this file to .env, fill in local credentials, then load it before
# starting the app:
#
#   set -a
#   source .env
#   set +a
#   python3 -m nda_automation.server --port 8787
#
# Do not commit the real .env file or Gmail token JSON files.

# Local storage
NDA_DATA_DIR=./data
NDA_EXPORTS_DIR=./exports

# Local auth. Leave disabled for trusted local development.
NDA_REQUIRE_AUTH=false
NDA_AUTH_USERNAME=
NDA_AUTH_PASSWORD=

# Rate limiting. Use 0 only for trusted local testing.
NDA_RATE_LIMIT_PER_MINUTE=0

# AI semantic review
NDA_AI_REVIEW_ENABLED=true
NDA_AI_PROVIDER=alibaba
NDA_AI_MODEL=qwen3.5-plus
NDA_AI_TIMEOUT_SECONDS=20
NDA_AI_REVIEW_THRESHOLD=0.75
NDA_AI_REVIEW_CLAUSES=

# Fill in only the provider key you are using.
ALIBABA_API_KEY=
DASHSCOPE_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Gmail OAuth token JSON paths
NDA_GMAIL_INBOUND_TOKEN_PATH=./data/gmail/inbound-token.json
NDA_GMAIL_OUTBOUND_TOKEN_PATH=./data/gmail/outbound-token.json

# Public/demo deployment escape hatch. Do not enable for durable production.
NDA_ALLOW_EPHEMERAL_DATA=false
