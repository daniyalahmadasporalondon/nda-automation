# Copy this file to .env, fill in local credentials, then load it before
# starting the app:
#
#   set -a
#   source .env
#   set +a
#   python3 -m nda_automation.server --port 8787
#
# Do not commit the real .env file or Gmail token JSON files.

# Local storage
NDA_DATA_DIR=./data
NDA_EXPORTS_DIR=./exports

# Local auth. Leave disabled for trusted local development.
NDA_REQUIRE_AUTH=false
NDA_AUTH_USERNAME=
NDA_AUTH_PASSWORD=

# Rate limiting. Use 0 only for trusted local testing.
NDA_RATE_LIMIT_PER_MINUTE=0

# AI semantic review
NDA_AI_REVIEW_ENABLED=true
NDA_AI_PROVIDER=openrouter
# NOTE: this local reviewer default (x-ai/grok-4.3) INTENTIONALLY differs from
# prod, which runs anthropic/claude-opus-4.8-fast (render.yaml NDA_AI_MODEL).
# Local reviews will therefore NOT behave identically to prod — to mirror prod
# behaviour locally, override NDA_AI_MODEL to the prod model in your .env.
NDA_AI_MODEL=x-ai/grok-4.3
# Per-request timeout for the single OpenRouter review call. Must exceed
# worst-case large-doc model latency (~2 min on a 120+ paragraph NDA);
# matches the 180s frontend timeout (static/app.js).
NDA_AI_TIMEOUT_SECONDS=180
NDA_AI_REVIEW_THRESHOLD=0.75
NDA_AI_REVIEW_CLAUSES=

# Active review engine defaults to AI-first with fail-closed behavior.
# Environment values pin runtime behavior; leave unset for Admin runtime controls.
NDA_ACTIVE_REVIEW_ENGINE=

# On-demand review. Inbound Gmail NDAs are NOT auto-reviewed: they import "Not
# Reviewed" and the full AI review (assessor + verifier) runs ONLY when a human
# clicks Review, drained off-request by a single persistent worker pool. (The
# former NDA_INBOUND_AI_REVIEW_ENABLED kill-switch is removed -- there is no
# inbound auto-review path to disable.)
# NDA_INBOUND_REVIEW_CONCURRENCY: default 1. The worker-pool size == the max
#   number of on-demand reviews running at once. Clamped to >= 1.
# NDA_GMAIL_IMPORT_LIMIT: default 20. Max inbound messages a SINGLE poll cycle
#   downloads + triages + classifies + text-extracts on the poll thread (gentle
#   catch-up). When Gmail is (re)connected the first poll would otherwise catch up
#   the whole 90-day backlog at once -- a one-time burst that can OOM the 2 GB
#   worker. Keeping this small drains the backlog a batch per poll: the persistent
#   dedup index skips already-imported messages BEFORE any download/extract, so
#   each cycle makes real progress until the backlog is empty. Raise to drain
#   faster at the cost of a larger per-poll burst. Clamped to >= 1.
# NDA_GMAIL_CUSTOM_TERMS_ENABLED: default FALSE (off). HARD safety gate. When OFF,
#   inbound NDA detection uses ONLY the hardcoded term floor -- behaviour is
#   byte-for-byte identical to having this feature absent. When ON, the admin-edited
#   "Signal Terms" (Gmail inbound_search_terms) are ADDED on top of that floor as
#   additive, LITERAL case-insensitive substring signals for the deterministic
#   CONTENT scorer only. They are NEVER added to the Gmail fetch query (broadening
#   the fetch is the inbox-storm vector), never change how many messages are
#   fetched, and never trigger synchronous review -- detections still flow through
#   the SAME deferred/on-demand pipeline. Terms are validated + capped (>=3 chars,
#   generic-word denylist, regex-neutralized, <=25 terms) at save and at read.
# NDA_GMAIL_ENVELOPE_EXCLUDES: default TRUE (on). Inbound sender excludes for
#   e-signature platform notifications + calendar invites (docusign.net/.com,
#   adobesign.com, documents.adobe.com, echosign.com, hellosign.com, pandadoc.com,
#   calendar-notification@google.com; admin-editable via the Gmail settings
#   inbound_excluded_senders list). Applied twice: the authoritative CODE-level
#   sender check (drops stay visible in skipped[] + the processed ledger, catches
#   forwarded notifications) and redundant query-level -from: clauses (fetch-quota
#   optimization). Set 0/false to restore the exact pre-exclude fetch query AND
#   the DocuSign-only code check (full rollback).
# NDA_GMAIL_ESIGN_NDA_CAPTURE: default TRUE (on). A platform notification whose
#   attachment filename or subject/body/snippet carries an EXPLICIT NDA signal is
#   captured through intake (clamped to the triage lane, provenance
#   triage_reason=esign_notification_nda) instead of terminally dropped -- the
#   completion email of a counterparty-initiated envelope is often the only copy
#   of an executed NDA that reaches the mailbox. Set 0/false to unconditionally
#   drop all platform notification mail.
# NDA_GMAIL_AI_PREGATE: default TRUE (on). Deterministic pre-gate on the paid AI
#   calls: candidates the deterministic scorer terminally skips (score < triage
#   band, no content basis) no longer pay for the Flash intake call, and the Pro
#   selector only runs when at least one candidate reaches the triage band.
#   MANDATORY fail-open exemptions keep the AI available for: explicit NDA
#   mentions in subject/body/snippet or a strong NDA filename (escape hatch), and
#   extraction-blind attachments (empty/<200 chars of text: image-only DOCX,
#   partial-scan PDF, foreign-language NDA). Set 0/false to restore the
#   always-call behaviour.
# NDA_GMAIL_FIRST_SYNC_CAP_DAYS: default 14. A NEWLY connected account's first
#   sync scans min(inbound_window_days, this) days and widens by the same step per
#   successful poll until reaching the configured window (default 90) -- bounding
#   the first-poll burst on a busy inbox. Existing connected users are unaffected.
#   Progress is visible as "backfilling: X of Y days" in the per-user sync status.
#   Set 0 to disable the cap.
NDA_INBOUND_REVIEW_CONCURRENCY=1
NDA_GMAIL_IMPORT_LIMIT=20
NDA_GMAIL_CUSTOM_TERMS_ENABLED=false
NDA_GMAIL_ENVELOPE_EXCLUDES=true
NDA_GMAIL_ESIGN_NDA_CAPTURE=true
NDA_GMAIL_AI_PREGATE=true
NDA_GMAIL_FIRST_SYNC_CAP_DAYS=14

# OpenRouter key used by NDA review and Gmail attachment selection.
OPENROUTER_API_KEY=

# Optional provider-backed adversarial verifier. This is an independent
# second-opinion model on OpenRouter, intentionally different from the main Grok
# review model. It uses the same OPENROUTER_API_KEY.
NDA_AI_VERIFIER=false
NDA_AI_VERIFIER_MODEL=deepseek/deepseek-v4-pro

# Scanned-PDF OCR fallback (DEFAULT-OFF). A scanned/image-only PDF (no text layer)
# otherwise hard-fails review with "Scanned PDFs need OCR". When enabled, the
# no-text pages are rasterized and transcribed by an OpenRouter VISION model using
# the SAME OPENROUTER_API_KEY above (no new key/dependency). This is a COST + LATENCY
# path, so it is bounded: at most NDA_PDF_OCR_MAX_PAGES pages are OCR'd (hard ceiling
# 20; the override may only LOWER it), each page carries a per-call timeout, and DPI
# is byte-budgeted. When OFF/unconfigured/failing, the clear scanned error is shown
# (never an empty/garbage "review").
NDA_PDF_OCR_ENABLED=false
NDA_PDF_OCR_MODEL=google/gemini-2.5-flash
NDA_PDF_OCR_MAX_PAGES=20
NDA_PDF_OCR_TIMEOUT_SECONDS=60
NDA_PDF_OCR_DPI=200

# Gmail OAuth token JSON paths
NDA_GMAIL_INBOUND_TOKEN_PATH=./data/gmail/inbound-token.json
NDA_GMAIL_OUTBOUND_TOKEN_PATH=./data/gmail/outbound-token.json

# DocuSign send-for-signature (REAL e-signature). Free developer-account quickstart:
#   1. Create a free DocuSign developer account at https://developers.docusign.com
#   2. In Apps & Keys: create an integration key (client id) + secret key,
#      and add your redirect URI (.../auth/docusign/callback) to the key.
#   3. Fill these in, restart, then click "Connect DocuSign" → real login.
# NDA_DOCUSIGN_AUTH_SERVER defaults to the DEMO environment (account-d.docusign.com
# auth; the eSignature API base URI is resolved per-account from /oauth/userinfo,
# e.g. https://demo.docusign.net), so a free dev account works out of the box.
# Flip to `production` (account.docusign.com) for live signing after go-live review.
NDA_DOCUSIGN_CLIENT_ID=
NDA_DOCUSIGN_CLIENT_SECRET=
NDA_DOCUSIGN_OAUTH_REDIRECT_URI=http://127.0.0.1:8787/auth/docusign/callback
NDA_DOCUSIGN_AUTH_SERVER=demo
# Optional: DocuSign Connect webhook HMAC secret. When set, /api/docusign/webhook
# verifies the X-DocuSign-Signature-1 header before processing the callback.
NDA_DOCUSIGN_CONNECT_HMAC_KEY=
# The SINGLE default Aspora signatory used for ALL Aspora signing entities when
# sending an envelope (the per-entity registry signatory has no email, so DocuSign
# can't route Aspora's copy without this). Set BOTH to make Aspora a routable
# signer on every generated NDA; leave either blank to omit the Aspora signer.
NDA_DOCUSIGN_ASPORA_SIGNER_NAME=
NDA_DOCUSIGN_ASPORA_SIGNER_EMAIL=

# Public/demo deployment escape hatch. Do not enable for durable production.
NDA_ALLOW_EPHEMERAL_DATA=false
