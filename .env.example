# Copy this file to .env, fill in local credentials, then load it before
# starting the app:
#
#   set -a
#   source .env
#   set +a
#   python3 -m nda_automation.server --port 8787
#
# Do not commit the real .env file or Gmail token JSON files.

# Local storage
NDA_DATA_DIR=./data
NDA_EXPORTS_DIR=./exports

# Local auth. Leave disabled for trusted local development.
NDA_REQUIRE_AUTH=false
NDA_AUTH_USERNAME=
NDA_AUTH_PASSWORD=

# Rate limiting. Use 0 only for trusted local testing.
NDA_RATE_LIMIT_PER_MINUTE=0

# AI semantic review
NDA_AI_REVIEW_ENABLED=true
NDA_AI_PROVIDER=openrouter
NDA_AI_MODEL=x-ai/grok-4.3
NDA_AI_TIMEOUT_SECONDS=20
NDA_AI_REVIEW_THRESHOLD=0.75
NDA_AI_REVIEW_CLAUSES=

# Active review engine defaults to AI-first with fail-closed behavior.
# Environment values pin runtime behavior; leave unset for Admin runtime controls.
NDA_ACTIVE_REVIEW_ENGINE=
NDA_AI_FIRST_REVIEW_ENABLED=false

# Inbound auto-review. Imported Gmail NDAs run a fast deterministic first-pass on
# the poll thread, then the full AI review (assessor + verifier) runs in the
# background via a single persistent worker pool draining a bounded queue.
# NDA_INBOUND_AI_REVIEW_ENABLED: default true. Set false (or 0/no/off) to
#   emergency-disable inbound auto-review entirely -- imported NDAs keep their
#   deterministic first-pass and stay reviewable on-demand, no redeploy needed.
# NDA_INBOUND_REVIEW_CONCURRENCY: default 1. The worker-pool size == the max
#   number of inbound reviews running at once. Clamped to >= 1.
# NDA_GMAIL_IMPORT_LIMIT: default 20. Max inbound messages a SINGLE poll cycle
#   downloads + triages + classifies + text-extracts on the poll thread (gentle
#   catch-up). When Gmail is (re)connected the first poll would otherwise catch up
#   the whole 90-day backlog at once -- a one-time burst that can OOM the 2 GB
#   worker. Keeping this small drains the backlog a batch per poll: the persistent
#   dedup index skips already-imported messages BEFORE any download/extract, so
#   each cycle makes real progress until the backlog is empty. Raise to drain
#   faster at the cost of a larger per-poll burst. Clamped to >= 1.
NDA_INBOUND_AI_REVIEW_ENABLED=true
NDA_INBOUND_REVIEW_CONCURRENCY=1
NDA_GMAIL_IMPORT_LIMIT=20

# OpenRouter key used by NDA review and Gmail attachment selection.
OPENROUTER_API_KEY=

# Optional provider-backed adversarial verifier. This is an independent
# second-opinion model on OpenRouter, intentionally different from the main Grok
# review model. It uses the same OPENROUTER_API_KEY.
NDA_AI_VERIFIER=false
NDA_AI_VERIFIER_MODEL=deepseek/deepseek-v4-pro

# Gmail OAuth token JSON paths
NDA_GMAIL_INBOUND_TOKEN_PATH=./data/gmail/inbound-token.json
NDA_GMAIL_OUTBOUND_TOKEN_PATH=./data/gmail/outbound-token.json

# DocuSign send-for-signature (REAL e-signature). Free developer-account quickstart:
#   1. Create a free DocuSign developer account at https://developers.docusign.com
#   2. In Apps & Keys: create an integration key (client id) + secret key,
#      and add your redirect URI (.../auth/docusign/callback) to the key.
#   3. Fill these in, restart, then click "Connect DocuSign" → real login.
# NDA_DOCUSIGN_AUTH_SERVER defaults to the DEMO environment (account-d.docusign.com
# auth; the eSignature API base URI is resolved per-account from /oauth/userinfo,
# e.g. https://demo.docusign.net), so a free dev account works out of the box.
# Flip to `production` (account.docusign.com) for live signing after go-live review.
NDA_DOCUSIGN_CLIENT_ID=
NDA_DOCUSIGN_CLIENT_SECRET=
NDA_DOCUSIGN_OAUTH_REDIRECT_URI=http://127.0.0.1:8787/auth/docusign/callback
NDA_DOCUSIGN_AUTH_SERVER=demo
# Optional: DocuSign Connect webhook HMAC secret. When set, /api/docusign/webhook
# verifies the X-DocuSign-Signature-1 header before processing the callback.
NDA_DOCUSIGN_CONNECT_HMAC_KEY=
# The SINGLE default Aspora signatory used for ALL Aspora signing entities when
# sending an envelope (the per-entity registry signatory has no email, so DocuSign
# can't route Aspora's copy without this). Set BOTH to make Aspora a routable
# signer on every generated NDA; leave either blank to omit the Aspora signer.
NDA_DOCUSIGN_ASPORA_SIGNER_NAME=
NDA_DOCUSIGN_ASPORA_SIGNER_EMAIL=

# Public/demo deployment escape hatch. Do not enable for durable production.
NDA_ALLOW_EPHEMERAL_DATA=false
